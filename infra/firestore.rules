rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Incidents: readable only by dispatcher or er_staff roles
    match /incidents/{sessionId} {
      allow read: if request.auth != null
        && request.auth.token.role in ['dispatcher', 'er_staff'];
      allow write: if request.auth != null
        && request.auth.token.role == 'dispatcher';
    }

    // All other collections: deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
