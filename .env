# ─── Gemini / Google AI ───────────────────────────────────────────────────────
# Your Gemini API key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=AIzaSyCYG08tyyIKW6zuTqk0vSgX_RScVadvJps

# Model used by Gemini Live — NEVER hardcode this in source files
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-latest
# ADK agents use generateContent (not Live API) — must be a text model
GEMINI_ADK_MODEL=gemini-2.5-flash

# ─── ElevenLabs ───────────────────────────────────────────────────────────────
# ElevenLabs API key (get from https://elevenlabs.io/app/settings/api-keys)
ELEVENLABS_API_KEY=caea5c6266d876ec077c826642577e42b14acd41ba6d7fb8959e2834ce25aae7

# ElevenLabs voice ID to use for medical instructions (e.g. "Adam", "Rachel")
# Sarah — calm, reassuring, works on premade plan (verified)
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
ELEVENLABS_VOICE_ID_2=eXpIbVcVbLo8ZJQDlDnl

# ─── Google Cloud ─────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=project-0e76dd9e-7b5a-4009-b1d

# Firestore collection where incident documents are stored
FIRESTORE_COLLECTION=incidents

# Pub/Sub topic for ER team notifications
PUBSUB_TOPIC=er-notifications

# Google Maps API key (for route calculation)
MAPS_API_KEY=AIzaSyC2bFztb_k4EhDXUAifyuuwVJTQM-A30Bk

# ─── App behaviour ────────────────────────────────────────────────────────────
# "elevenlabs" = ElevenLabs HD voice for MedicalAgent output
# "gemini"     = fallback to Gemini Live native audio (resilience switch)
VOICE_MODE=elevenlabs

# Set to "true" on demo day fallback: replaces all live API calls with fixtures
# Local dev: true skips Firestore/Pub/Sub (no GCP auth needed)
# Production/demo day: set to false
DEMO_MODE=true
